{
  "openapi": "3.0.0",
  "info": {
    "title": "Hệ thống Quản lý Nhân sự (HRM) - API Documentation",
    "version": "1.0.0",
    "description": "Tài liệu API đầy đủ cho hệ thống quản lý nhân sự, bao gồm quản lý hồ sơ, lương, tuyển dụng, định mức giảng dạy và quy trình phê duyệt."
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "API Version 1"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": {
            "type": "object",
            "properties": {
              "message": { "type": "string" },
              "code": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["Xác thực"],
        "summary": "Đăng nhập hệ thống",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Đăng nhập thành công" }
        }
      }
    },
    "/auth/permissions": {
      "get": {
        "tags": ["Xác thực"],
        "summary": "Lấy danh sách quyền hạn và phạm vi (scopes) của người dùng hiện tại",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Thành công" }
        }
      }
    },
    "/admin/users": {
      "get": {
        "tags": ["Quản trị hệ thống"],
        "summary": "Danh sách người dùng",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Thành công" }
        }
      },
      "post": {
        "tags": ["Quản trị hệ thống"],
        "summary": "Tạo người dùng mới",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Đã tạo" }
        }
      }
    },
    "/admin/audit-logs": {
      "get": {
        "tags": ["Quản trị hệ thống"],
        "summary": "Xem nhật ký hệ thống (Audit Logs)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Thành công" }
        }
      }
    },
    "/admin/workflows/{id}/metadata": {
      "put": {
        "tags": ["Quản trị hệ thống"],
        "summary": "Admin chỉnh sửa dữ liệu đang chờ duyệt trong quy trình",
        "description": "Cho phép Admin sửa lại thông tin (metadata) của một yêu cầu trước khi bấm nút Duyệt cuối cùng.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "metadata": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Cập nhật thành công" }
        }
      }
    },
    "/profiles/me": {
      "get": {
        "tags": ["Hồ sơ cán bộ"],
        "summary": "Lấy thông tin hồ sơ của chính mình",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Thành công" }
        }
      }
    },
    "/profiles": {
      "get": {
        "tags": ["Hồ sơ cán bộ"],
        "summary": "Danh sách hồ sơ cán bộ (có phân quyền theo đơn vị)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Thành công" }
        }
      },
      "post": {
        "tags": ["Hồ sơ cán bộ"],
        "summary": "Tạo hồ sơ mới",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Đã tạo" }
        }
      }
    },
    "/profiles/{id}": {
      "get": {
        "tags": ["Hồ sơ cán bộ"],
        "summary": "Chi tiết hồ sơ theo ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Thành công" } }
      },
      "put": {
        "tags": ["Hồ sơ cán bộ"],
        "summary": "Cập nhật hồ sơ (Khởi tạo quy trình phê duyệt)",
        "description": "Khi gọi API này, hồ sơ sẽ chuyển sang trạng thái 'pending' và tạo một Workflow để chờ Admin duyệt. Dữ liệu thật sẽ không thay đổi cho đến khi được duyệt.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Yêu cầu đã được gửi" } }
      }
    },
    "/profiles/{id}/education": {
      "get": {
        "tags": ["Hồ sơ - Tiểu mục"],
        "summary": "Lấy quá trình đào tạo",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Thành công" } }
      },
      "post": {
        "tags": ["Hồ sơ - Tiểu mục"],
        "summary": "Thêm bản ghi đào tạo",
        "security": [{ "bearerAuth": [] }],
        "responses": { "201": { "description": "Đã tạo" } }
      }
    },
    "/salary/proposals": {
      "get": {
        "tags": ["Quản lý Lương"],
        "summary": "Danh sách đề xuất nâng lương",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Thành công" } }
      },
      "post": {
        "tags": ["Quản lý Lương"],
        "summary": "Tạo đề xuất nâng lương mới",
        "security": [{ "bearerAuth": [] }],
        "responses": { "201": { "description": "Đã tạo" } }
      }
    },
    "/workload/me": {
      "get": {
        "tags": ["Khối lượng giảng dạy"],
        "summary": "Xem định mức và minh chứng của bản thân",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Thành công" } }
      }
    },
    "/workload/evidences": {
      "get": {
        "tags": ["Khối lượng giảng dạy"],
        "summary": "Danh sách minh chứng chờ duyệt (dành cho quản lý)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Thành công" } }
      },
      "post": {
        "tags": ["Khối lượng giảng dạy"],
        "summary": "Khai báo minh chứng công việc mới",
        "security": [{ "bearerAuth": [] }],
        "responses": { "201": { "description": "Đã tạo" } }
      }
    },
    "/workload/evidences/{id}/approve": {
      "post": {
        "tags": ["Khối lượng giảng dạy"],
        "summary": "Duyệt minh chứng",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Đã duyệt" } }
      }
    },
    "/attachments/upload": {
      "post": {
        "tags": ["Tài liệu đính kèm"],
        "summary": "Tải lên file (Minh chứng, Quyết định...)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" },
                  "resource_type": { "type": "string" },
                  "resource_id": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Tải lên thành công" } }
      }
    }
  }
}
