{
    "name": "backend",
    "version": "1.0.0",
    "description": "HRM Backend — ĐHQGHN",
    "license": "ISC",
    "author": "",
    "type": "commonjs",
    "main": "dist/server.js",
    "directories": {
        "test": "tests"
    },
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "migrate": "psql $DATABASE_URL -f src/db/migrations/001_initial_schema.sql",
        "seed": "psql $DATABASE_URL -f src/db/seeds/01_roles.sql -f src/db/seeds/02_permissions.sql",
        "test": "jest --runInBand",
        "test:cov": "jest --coverage",
        "test:watch": "jest --watch",
        "lint": "eslint . --ext .ts",
        "lint:fix": "eslint . --ext .ts --fix"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "dayjs": "^1.11.19",
        "dotenv": "^17.3.1",
        "express": "^4.22.1",
        "express-rate-limit": "^8.3.1",
        "helmet": "^8.1.0",
        "ioredis": "^5.10.0",
        "jsonwebtoken": "^9.0.3",
        "lodash": "^4.17.23",
        "morgan": "^1.10.1",
        "multer": "^2.1.1",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.2",
        "pg": "^8.20.0",
        "pg-pool": "^3.13.0",
        "uuid": "^13.0.0",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0",
        "zod": "^3.25.76",
        "zod-express-middleware": "^1.4.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/dotenv": "^6.1.1",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/lodash": "^4.17.24",
        "@types/morgan": "^1.9.10",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.4.0",
        "@types/node-cron": "^3.0.11",
        "@types/pg": "^8.18.0",
        "@types/supertest": "^7.2.0",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "jest": "^30.3.0",
        "prettier": "^3.8.1",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0"
    }
}